#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

VERSION="1.1.1"
TARGET="$(rustc -vV | awk '/^host: / {print $2}')"
OUT_DIR=""
KEEP_ARCHIVE=0

usage() {
  cat <<'USAGE'
Usage: ./scripts/fetch-libcurl-impersonate [options]

Download versioned impcurl libcurl-impersonate assets into vendor/<target>/lib.

Options:
  --target <triple>      Rust target triple (default: rustc host target)
  --version <ver>        Asset version (default: 1.1.1)
  --out-dir <dir>        Output directory (default: vendor/<target>/lib)
  --keep-archive         Keep downloaded archive
  -h, --help             Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      TARGET="$2"
      shift 2
      ;;
    --version)
      VERSION="$2"
      shift 2
      ;;
    --out-dir)
      OUT_DIR="$2"
      shift 2
      ;;
    --keep-archive)
      KEEP_ARCHIVE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ -z "${OUT_DIR}" ]]; then
  OUT_DIR="${ROOT_DIR}/vendor/${TARGET}/lib"
fi

ASSET_BASENAME="impcurl-libcurl-impersonate-v${VERSION}-${TARGET}.tar.gz"
URL="https://github.com/tuchg/impcurl/releases/download/impcurl-libcurl-impersonate-v${VERSION}/${ASSET_BASENAME}"

mkdir -p "${OUT_DIR}"
TMP_ARCHIVE="${OUT_DIR}/${ASSET_BASENAME}"
TMP_EXTRACT_DIR="$(mktemp -d "${OUT_DIR}/.extract.XXXXXX")"

if command -v curl >/dev/null 2>&1; then
  echo "+ curl -fL ${URL} -o ${TMP_ARCHIVE}"
  curl -fL "${URL}" -o "${TMP_ARCHIVE}"
elif command -v wget >/dev/null 2>&1; then
  echo "+ wget -O ${TMP_ARCHIVE} ${URL}"
  wget -O "${TMP_ARCHIVE}" "${URL}"
else
  echo "error: curl or wget is required" >&2
  exit 1
fi

echo "+ unpack ${TMP_ARCHIVE} -> ${TMP_EXTRACT_DIR}"
tar -xzf "${TMP_ARCHIVE}" -C "${TMP_EXTRACT_DIR}"

collect_patterns=()
if [[ "${TARGET}" == *windows* ]]; then
  collect_patterns=("*.dll")
elif [[ "${TARGET}" == *apple-darwin* || "${TARGET}" == *darwin* ]]; then
  collect_patterns=("*.dylib")
else
  collect_patterns=("*.so*")
fi

COPIED_RUNTIME_LIST="$(mktemp)"
COPIED_STATIC_LIST="$(mktemp)"

for pattern in "${collect_patterns[@]}"; do
  while IFS= read -r -d '' candidate; do
    dst="${OUT_DIR}/$(basename "${candidate}")"
    if [[ "${candidate}" != "${dst}" ]]; then
      cp -f "${candidate}" "${dst}"
    fi
    printf '%s\n' "${dst}" >> "${COPIED_RUNTIME_LIST}"
  done < <(find "${TMP_EXTRACT_DIR}" -type f -name "${pattern}" -print0)
done

while IFS= read -r -d '' candidate; do
  dst="${OUT_DIR}/$(basename "${candidate}")"
  if [[ "${candidate}" != "${dst}" ]]; then
    cp -f "${candidate}" "${dst}"
  fi
  printf '%s\n' "${dst}" >> "${COPIED_STATIC_LIST}"
done < <(find "${TMP_EXTRACT_DIR}" -type f -name '*.a' -print0)

rm -rf "${TMP_EXTRACT_DIR}"

if [[ "${KEEP_ARCHIVE}" -eq 0 ]]; then
  rm -f "${TMP_ARCHIVE}"
fi

echo "done"
echo "target: ${TARGET}"
echo "libcurl-impersonate asset version: ${VERSION}"
echo "source: ${URL}"
echo "output: ${OUT_DIR}"
ls -la "${OUT_DIR}"
echo "shared libs:"
if [[ -s "${COPIED_RUNTIME_LIST}" ]]; then
  sort -u "${COPIED_RUNTIME_LIST}"
else
  echo "(none copied from this archive)"
fi
echo "static libs:"
if [[ -s "${COPIED_STATIC_LIST}" ]]; then
  sort -u "${COPIED_STATIC_LIST}"
else
  echo "(none copied from this archive)"
fi

shared_count="$(wc -l < "${COPIED_RUNTIME_LIST}" | tr -d '[:space:]')"
if [[ "${shared_count}" == "0" ]]; then
  echo "warning: no shared library (*.dylib/*.so/*.dll) found in ${OUT_DIR}" >&2
  echo "warning: this asset may be static-only (*.a), which cannot be used by dynamic loading." >&2
fi

rm -f "${COPIED_RUNTIME_LIST}" "${COPIED_STATIC_LIST}"
